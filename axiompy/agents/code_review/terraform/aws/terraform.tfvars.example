# Code Review Agent - AWS Terraform Variables
#
# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars
#
# Then run:
#   terraform init
#   terraform plan
#   terraform apply
#
# NOTE: terraform.tfvars is gitignored to prevent committing secrets.

#------------------------------------------------------------------------------
# Required - You must set these
#------------------------------------------------------------------------------

# GitHub token for posting reviews
# Create at: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo
github_token = "ghp_your_token_here"

# Repository containing AGENTS.md rules
rules_repo = "varonusmaximus/axiompy"

# Webhook secret for verifying GitHub signatures (RECOMMENDED for production)
# Generate a random secret: openssl rand -hex 32
# Then set the same secret in GitHub webhook settings
webhook_secret = ""

#------------------------------------------------------------------------------
# Performance - GPU Configuration (RECOMMENDED)
#------------------------------------------------------------------------------

# Enable GPU for 10-20x faster inference
# GPU (g5.xlarge): ~20-30 seconds per file
# CPU (Fargate):   ~3-5 minutes per file
enable_gpu = true

# GPU instance type (only used if enable_gpu = true)
# g5.xlarge  = A10G GPU, best price/performance (~$1.00/hr)
# g5.2xlarge = A10G GPU, more CPU/RAM (~$1.50/hr)
# g4dn.xlarge = T4 GPU, budget option (~$0.50/hr)
gpu_instance_type = "g5.xlarge"

# Ollama model (any model from https://ollama.com/library)
# qwen2.5-coder:1.5b = Fast, code-focused (default)
# llama3.2:1b   = Fast, good for quick reviews
# mistral:latest = More accurate, slower
# codellama     = Code-specialized (legacy)
ollama_model = "qwen2.5-coder:1.5b"

#------------------------------------------------------------------------------
# Cost Optimization
#------------------------------------------------------------------------------

# High Availability: Use multiple NAT Gateways for redundancy
# true  = 2 NAT Gateways (~$64/month) - recommended for production
# false = 1 NAT Gateway (~$32/month) - ok for dev/staging
high_availability = true

#------------------------------------------------------------------------------
# Optional - Defaults shown
#------------------------------------------------------------------------------

# AWS region
aws_region = "us-west-2"

# Environment name (production, staging, development)
environment = "production"

# Rules file path in repository
rules_file = "AGENTS.md"

# Logging level (DEBUG, INFO, WARNING, ERROR)
log_level = "INFO"

# Number of ECS tasks to run
desired_count = 1

# VPC CIDR block
vpc_cidr = "10.0.0.0/16"

#------------------------------------------------------------------------------
# HTTPS (Recommended for Production)
#------------------------------------------------------------------------------

# ACM certificate ARN for HTTPS (leave empty for HTTP only)
# To create a certificate:
#   1. Go to AWS Certificate Manager
#   2. Request a public certificate
#   3. Validate via DNS
#   4. Copy the ARN here
# certificate_arn = "arn:aws:acm:us-west-2:123456789:certificate/abc-123"
certificate_arn = ""

#------------------------------------------------------------------------------
# Observability
#------------------------------------------------------------------------------

# Enable ALB access logs to S3 (useful for debugging webhook issues)
enable_alb_logs = false

#------------------------------------------------------------------------------
# Remote State (RECOMMENDED for teams)
#------------------------------------------------------------------------------

# For production deployments, configure an S3 backend in main.tf:
#
# 1. Create S3 bucket for state:
#    aws s3 mb s3://your-terraform-state-bucket
#
# 2. Create DynamoDB table for locking:
#    aws dynamodb create-table \
#      --table-name terraform-locks \
#      --attribute-definitions AttributeName=LockID,AttributeType=S \
#      --key-schema AttributeName=LockID,KeyType=HASH \
#      --billing-mode PAY_PER_REQUEST
#
# 3. Uncomment the backend block in main.tf and configure bucket/region
