# Code Review Agent - Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then run:
#   docker compose up -d

# =============================================================================
# REQUIRED
# =============================================================================

# GitHub token for posting reviews
# Create at: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public only)
GITHUB_TOKEN=ghp_your_token_here

# =============================================================================
# OPTIONAL - Defaults shown
# =============================================================================

# Central repository containing AGENTS.md rules
# Format: owner/repo
RULES_REPO=your-org/axiompy

# Path to rules file in the repo
RULES_FILE=AGENTS.md

# Ollama model to use for code review
# Options: codellama, codellama:13b, codellama:34b, deepseek-coder, llama3
OLLAMA_MODEL=codellama

# GitHub webhook secret (for signature verification)
# Generate with: openssl rand -hex 32
# WEBHOOK_SECRET=

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
